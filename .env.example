# DB (PostgreSQL requerido)
# Local: postgresql://user:password@localhost:5432/dentcode
# Render: se configura automáticamente al crear la base de datos
DATABASE_URL="postgresql://postgres:password@localhost:5432/dentcode"

# JWT Secret para autenticación (generar uno seguro para producción)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN="dentcode-verify"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
TZ="America/Santiago"
LOCALE="es-CL"
CURRENCY="CLP"
